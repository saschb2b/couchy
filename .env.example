# Optional. Only required if you want to call official api.steampowered.com endpoints.
# The two storefront endpoints Couchy depends on (search/results and appdetails) do NOT need a key.
STEAM_API_KEY=

# Country code for prices (default: us). Examples: us, de, gb, jp.
STEAM_CC=us

# Locale for store text (default: english). Examples: english, german, french, schinese.
STEAM_LOCALE=english
